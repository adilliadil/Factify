# ──────────────────────────────────────────────
# Factify — Environment Variables
# Copy this file to .env and fill in your keys.
# ──────────────────────────────────────────────

# ── Required ──────────────────────────────────

# OpenAI API key (used for claim extraction & evidence analysis)
OPENAI_API_KEY=

# Tavily API key (used for web search)
TAVILY_API_KEY=

# Nebius API key (used for eval judge model)
# Get one at https://tokenfactory.nebius.com/project/api-keys
NEBIUS_API_KEY=

# ── Optional (have sensible defaults) ────────

# LLM model & endpoint for the backend pipeline
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# Judge model & endpoint for evals (Nebius AI Studio)
# JUDGE_MODEL=deepseek-ai/DeepSeek-V3-0324
# JUDGE_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# ── Secondary LLMs for benchmarking  ────────
SECONDARY_LLM_API_KEY=
SECONDARY_LLM_BASE_URL=https://202604-resource.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview
GROK_REASONING_MODEL_NAME=grok-4-20-reasoning
GROK_NONREASONING_MODEL_NAME=grok-4-20-non-reasoning
KIMI_MODEL_NAME=Kimi-K2.5
DEEPSEEK_R_MODEL_NAME=DeepSeek-R1-0528

# Weird ones
DEEPSEEK_V_MODEL_NAME=DeepSeek-V3.2
LLAMA_MODEL_NAME=Llama-4-Maverick-17B-128E-Instruct-FP8
SECONDARY_LLM_WEIRDOS_BASE_URL=https://aydin-m6k85syj-westus.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview
SECONDARY_LLM_WEIRDOS_KEY=

# OpenAI
SECONDARY_LLM_OPENAI_BASE_URL=https://202604-resource.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
SECONDARY_LLM_OPENAI_KEY=
GPT_NANO_MODEL_NAME=gpt-5.4-nano
GPT_MINI_MODEL_NAME=gpt-5.4-mini
