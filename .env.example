# ──────────────────────────────────────────────
# Factify — Environment Variables
# Copy this file to .env and fill in your keys.
# ──────────────────────────────────────────────

# ── How the pipeline / judge LLM is chosen ────────────────
#
# 1) Registry alias (recommended for Grok, Kimi, etc.)
#    If LLM_MODEL or JUDGE_MODEL is an alias defined under "Secondary LLMs" below (e.g.
#    grok-reasoning), the app uses that block's URL and key. LLM_PROVIDER does *not*
#    select the endpoint in that case — the registry entry wins.
#
# 2) Otherwise LLM_PROVIDER picks the client: openai, openai_compatible (incl. Nebius),
#    azure, or azure_inference — see the commented blocks for each.
#
# 3) LLM_PROVIDER=azure means Azure OpenAI *Service* (classic resource at
#    https://<resource>.openai.azure.com). It uses AZURE_OPENAI_API_KEY, ENDPOINT, and
#    API_VERSION below. That is not the same as AZURE_BASE_URL / AZURE_OPENAI_BASE_URL
#    in the registry (those are Azure AI model inference chat/completions URLs).
#
# 4) LLM_PROVIDER=azure_inference is for a single custom endpoint via LLM_INFERENCE_*.
#
# Example — use Grok for the fact-check pipeline:
#   - Fill AZURE_BASE_URL and AZURE_API_KEY (both required for this registry group).
#   - Set GROK_REASONING_MODEL_NAME or GROK_NONREASONING_MODEL_NAME to the deployment
#     name your Azure endpoint expects (as shown in Azure AI Studio / your deployment).
#   - Set LLM_MODEL=grok-reasoning or LLM_MODEL=grok-nonreasoning (uncomment in your .env).
#   You do not set LLM_PROVIDER=azure for this; aliases use the registry, not Azure OpenAI Service.

# ── Optional settings with fallbacks in the code ────────

# LLM model & endpoint for the backend pipeline
# LLM_PROVIDER=openai          # openai | openai_compatible | nebius | azure | azure_inference
# LLM_MODEL=gpt-4o-mini        # or a registry alias: grok-reasoning, kimi, gpt-nano, … (see Secondary LLMs below)
# LLM_BASE_URL=https://api.openai.com/v1

# Judge model & endpoint for evals (Nebius AI Studio)
# JUDGE_PROVIDER=openai_compatible  # openai | openai_compatible | nebius | azure | azure_inference
# JUDGE_MODEL=deepseek-ai/DeepSeek-V3-0324   # or any registry alias (same list as LLM_MODEL)
# JUDGE_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# Azure AI / model inference endpoints (when *_PROVIDER=azure_inference)
# HTTP_INFERENCE_MAX_RETRIES=3 # retries after 429 / 5xx / transient errors (default 3; also applies to registry azure_inference aliases)
# LLM_INFERENCE_URL=           # full chat/completions URL (may include api-version)
# LLM_INFERENCE_API_KEY=       # or reuse SECONDARY_LLM_API_KEY
# LLM_INFERENCE_API_KEY_HEADER=api-key
#
# JUDGE_INFERENCE_URL=
# JUDGE_INFERENCE_API_KEY=
# JUDGE_INFERENCE_API_KEY_HEADER=api-key

# Optional override: use a different Azure OpenAI resource for the judge
# JUDGE_AZURE_OPENAI_API_KEY=
# JUDGE_AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# JUDGE_AZURE_OPENAI_API_VERSION=2024-xx-xx

# ── Now set the keys ──────────────────────────────────

# Tavily API key (used for web search)
TAVILY_API_KEY=

OPENAI_API_KEY=
NEBIUS_API_KEY=

# Azure OpenAI *Service* only — used when LLM_PROVIDER=azure or JUDGE_PROVIDER=azure
# (resource-based API; not used when LLM_MODEL is a registry alias like grok-reasoning).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-xx-xx

# ── Secondary LLMs (model registry) ────────
# Each group below registers aliases. Set LLM_MODEL / JUDGE_MODEL to the alias name.
# When AZURE_* / AZURE_WEIRDOS_* / AZURE_OPENAI_* (registry) groups below are set, you can set
# LLM_MODEL or JUDGE_MODEL to an alias: grok-reasoning, grok-nonreasoning, kimi, deepseek-r,
# deepseek-v, llama-maverick, gpt-nano, gpt-mini, gpt-5.4
AZURE_BASE_URL=https://202604-resource.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview
AZURE_API_KEY=
# GROK_MAX_COMPLETION_TOKENS=4000  # Grok registry aliases only (reasoning uses many internal tokens; default 4000)
GROK_REASONING_MODEL_NAME=grok-4-20-reasoning
GROK_NONREASONING_MODEL_NAME=grok-4-20-non-reasoning
KIMI_MODEL_NAME=Kimi-K2.5
DEEPSEEK_R_MODEL_NAME=DeepSeek-R1-0528

# Weird ones
AZURE_WEIRDOS_BASE_URL=https://aydin-m6k85syj-westus.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview
AZURE_WEIRDOS_KEY=
DEEPSEEK_V_MODEL_NAME=DeepSeek-V3.2
LLAMA_MODEL_NAME=Llama-4-Maverick-17B-128E-Instruct-FP8

# Azure OpenAI Service (cognitiveservices / openai.azure.com) for gpt-nano, gpt-mini & gpt-5.4 aliases.
# Use either the resource root (deployment URL is built from GPT_*_MODEL_NAME) or a full URL:
#   https://<resource>.cognitiveservices.azure.com
#   https://<resource>.cognitiveservices.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-08-01-preview
# Optional: AZURE_OPENAI_REGISTRY_API_VERSION=2024-12-01-preview  (when using a bare resource URL above)
AZURE_OPENAI_BASE_URL=https://202604-resource.cognitiveservices.azure.com
AZURE_OPENAI_KEY=
GPT_NANO_MODEL_NAME=gpt-5.4-nano
GPT_MINI_MODEL_NAME=gpt-5.4-mini
GPT_MODEL_NAME=gpt-5.4
